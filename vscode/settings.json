{
  // "workbench.statusBar.visible": false,
  "explorer.openEditors.visible": 1,
  "workbench.activityBar.visible": false,
  "editor.tabCompletion": "on",
  "window.openFilesInNewWindow": "on",
  "workbench.iconTheme": "vscode-great-icons",
  "editor.minimap.enabled": false,
  "window.menuBarVisibility": "toggle",
  "editor.fontFamily": "'Fira Code', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
  "editor.fontLigatures": true,
  "window.titleBarStyle": "custom",
  "explorer.autoReveal": false,
  "editor.formatOnSave": true,
  "search.useIgnoreFiles": false,
  "prettier.trailingComma": "es5",
  "css.lint.unknownAtRules": "ignore",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 3,
  "editor.wordWrap": "on",
  "editor.cursorBlinking": "solid",
  "editor.colorDecorators": false,
  "editor.renderWhitespace": "none",
  "editor.rulers": [120],
  "workbench.startupEditor": "newUntitledFile",
  "workbench.editor.tabCloseButton": "off",
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "vue-html": "html",
    "blade": "html"
  },
  // show snippets before any other auto completion
  "editor.snippetSuggestions": "top",
  // this lets you quickly open multiple items in a row and not have the previous ones closed on you
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "window.title": "${dirty} ${activeEditorMedium}${separator}${rootName}",
  "[git-commit]": {
    "editor.rulers": [72]
  },
  "workbench.editor.tabSizing": "shrink",
  "html.format.enable": true,
  "html.format.preserveNewLines": true,
  "files.trimTrailingWhitespace": true,
  "editor.fontSize": 12,
  "editor.lineHeight": 18,
  "editor.letterSpacing": 1,
  "editor.fontWeight": "400",
  "html.format.wrapAttributes": "force-expand-multiline",
  "html.format.wrapLineLength": 120,
  "javascript.validate.enable": false,
  "javascript.format.enable": false,
  "editor.parameterHints.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.colorTheme": "Tokyo Night",
  "terminal.integrated.fontWeight": "100",
  "terminal.integrated.fontWeightBold": "100",
  // "terminal.integrated.shell.windows": "C:\\Windows\\System32\\wsl.exe",
  "terminal.integrated.fontFamily": "Fira Code",
  "cSpell.userWords": ["gmail", "smartsalesandlease", "smtp", "smtps"],
  "files.associations": {
    "*.vue": "vue"
  },
  "javascript.preferences.quoteStyle": "single",
  "files.eol": "\n",
  "workbench.colorCustomizations": {
    "[Night Owl]": {
      "sideBar.foreground": "#8BADC1",
      "editorGroup.emptyBackground": "#011627",
      "sideBar.border": "#102A44"
    },
    "[Night Owl No Italics]": {
      "sideBar.foreground": "#8BADC1",
      "editorGroup.emptyBackground": "#011627",
      "sideBar.border": "#102A44"
    }
  },
  "prettier.singleQuote": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "javascript.format.semicolons": "insert",
  "typescript.format.semicolons": "insert",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "go.toolsManagement.autoUpdate": true,
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter"
  },
  "debug.javascript.autoAttachFilter": "smart",
  "[python]": {
    "editor.formatOnType": true
  },
  "svelte.enable-ts-plugin": true,
  "editor.detectIndentation": false,
  "redhat.telemetry.enabled": false
}
