# Docker aliases
alias docker-up='function _dockerup() { docker-compose up $1 -d }; _dockerup'
alias docker-down='function _dockerdown() { docker-compose down }; _dockerdown'
alias docker-bash='function _dockerbash() { docker exec -e COLUMNS="`tput cols`" -e LINES="`tput lines`" -ti $1 bash }; _dockerbash'
alias docker-stop='function _dockerstop() { docker-compose stop }; _dockerstop'
alias docker-start='function _dockerstart() { docker-compose start }; _dockerstart'

# Git aliases
alias gs='git status'
alias gp='git push'
alias ga='git add'
alias gaa='git add .'
alias gc='git commit -m'
alias gb="git branch"
alias gco='git checkout'
alias gm='git merge --no-ff'

# Gitflow aliases
alias gffs='git flow feature start $1'
alias gfff='git flow feature finish $1'
alias gfrs='git flow release start $1'
alias gfrf='git flow release finish $1'
alias gfhf='git flow hotfix start $1'
alias gfhf='git flow hotfix finish $1'

# Laravel aliases
alias artisan='php artisan'

# NPM aliases
alias ni='npm install'
alias nis='npm install --save $1'
alias nisd='npm install --save-dev $1'
alias nr='npm run $1'

# Unix aliases
alias please='sudo $(fc -ln -1)'

