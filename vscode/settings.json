{
	"workbench.statusBar.visible": false,
	"explorer.openEditors.visible": 0,
	"workbench.activityBar.visible": false,
	"editor.tabCompletion": "on",
	"window.openFilesInNewWindow": "on",
	"workbench.iconTheme": "material-icon-theme",
	"editor.minimap.enabled": false,
	"window.menuBarVisibility": "toggle",
	"editor.fontFamily": "'Fira Code', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
	"editor.fontLigatures": true,
	"terminal.integrated.rendererType": "dom",
	"scss.validate": false,
	"window.titleBarStyle": "custom",
	"explorer.autoReveal": false,
	"editor.formatOnSave": true,
	"eslint.autoFixOnSave": true,
	"eslint.alwaysShowStatus": true,
	"search.useIgnoreFiles": false,
	"prettier.trailingComma": "es5",
	"css.lint.unknownAtRules": "ignore",
	"vetur.format.defaultFormatterOptions": {
		"prettyhtml": {
			"printWidth": 80, // No line exceeds 80 characters
			"singleQuote": true // Prefer double quotes over single quotes
		}
	},
	"prettier.eslintIntegration": true,
	"editor.cursorStyle": "line",
	"editor.cursorWidth": 3,
	"editor.wordWrap": "on",
	"editor.cursorBlinking": "solid",
	"editor.colorDecorators": false,
	"editor.renderWhitespace": "none",
	"editor.rulers": [80],
	"workbench.startupEditor": "newUntitledFile",
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/.next": true,
		"**/.nuxt": true
	},
	"workbench.editor.tabCloseButton": "off",
	"emmet.includeLanguages": {
		"javascript": "javascriptreact",
		"vue-html": "html"
	},
	// show snippets before any other auto completion
	"editor.snippetSuggestions": "top",
	// this lets you quickly open multiple items in a row and not have the previous ones closed on you
	"workbench.editor.enablePreviewFromQuickOpen": false,
	"window.title": "${dirty} ${activeEditorMedium}${separator}${rootName}",
	"[git-commit]": {
		"editor.rulers": [72]
	},
	"workbench.editor.tabSizing": "shrink",
	"html.format.enable": true,
	"html.format.preserveNewLines": true,
	"files.trimTrailingWhitespace": true,
	"window.zoomLevel": -1,
	"editor.fontSize": 14,
	"editor.lineHeight": 18,
	"editor.letterSpacing": 1,
	"editor.fontWeight": "400",
	"eslint.packageManager": "npm",
	"html.format.wrapAttributes": "force-expand-multiline",
	"html.format.wrapLineLength": 80,
	"vetur.validation.template": false,
	"vetur.format.defaultFormatter.scss": "prettier",
	"eslint.options": { "extensions": [".html", ".js", ".vue", ".jsx"] },
	"eslint.validate": ["javascript", "javascriptreact", "vue", "vue-html"],
	"javascript.validate.enable": false,
	"javascript.format.enable": false,
	"editor.parameterHints.enabled": false,
	"workbench.editor.enablePreview": false,
	"workbench.colorTheme": "Night Owl",
	"terminal.integrated.fontWeight": "100",
	"terminal.integrated.fontWeightBold": "100",
	"terminal.integrated.shell.windows": "C:\\Windows\\System32\\wsl.exe",
	"terminal.integrated.fontFamily": "Fira Code",
	"prettier.tabWidth": 4,
	"prettier.useTabs": true,
	"vetur.format.options.tabSize": 4,
	"vetur.format.defaultFormatter.html": "js-beautify-html",
	"editor.insertSpaces": false,
	"cSpell.userWords": ["gmail", "smartsalesandlease", "smtp", "smtps"],
	"material-icon-theme.showWelcomeMessage": false,
	"files.associations": {
		"*.vue": "vue"
	},
	"prettier.printWidth": 80,
	"javascript.preferences.quoteStyle": "single",
	"files.eol": "\n",
	"workbench.colorCustomizations": {
		"[Night Owl]": {
			"sideBar.foreground": "#8BADC1",
			"editorGroup.emptyBackground": "#011627",
			"sideBar.border": "#102A44"
		},
		"[Night Owl No Italics]": {
			"sideBar.foreground": "#8BADC1",
			"editorGroup.emptyBackground": "#011627",
			"sideBar.border": "#102A44"
		}
	},
	"prettier.singleQuote": true
}
